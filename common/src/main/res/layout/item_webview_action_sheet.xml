<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/horizontal_margin_l"
    android:paddingEnd="@dimen/horizontal_margin_l">

    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_webview_action_tile">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivActionIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:contentDescription="@null" />
    </FrameLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvActionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/vertical_margin_m"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="@color/autoColor"
        android:textSize="@dimen/font_size_l" />
</LinearLayout>
