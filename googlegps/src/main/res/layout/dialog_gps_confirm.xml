<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_confirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/dialog_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:textColor="#333333"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="为了您更好的体验，应用需要访问后台定位权限。" />

        <View
            android:id="@+id/h_line"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dialog_textView" />

        <!-- 双按钮：取消 | 确定 -->
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/gps_cancel"
            android:textColor="#666666"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@id/s_line"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_line" />

        <View
            android:id="@+id/s_line"
            android:layout_width="1dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@id/dialog_cancel"
            app:layout_constraintEnd_toStartOf="@id/dialog_confirm"
            app:layout_constraintStart_toEndOf="@id/dialog_cancel"
            app:layout_constraintTop_toTopOf="@id/dialog_cancel" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/dialog_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/gps_confirm"
            android:textColor="#333333"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/s_line"
            app:layout_constraintTop_toBottomOf="@id/h_line" />

        <!-- 三按钮：纵向排列，用于后台定位等场景 -->
        <LinearLayout
            android:id="@+id/three_button_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/h_line">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/dialog_confirm_vertical"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#1677FF"
                android:textSize="16sp"
                tools:text="Go to settings" />

            <View
                android:id="@+id/line_confirm_neutral"
                android:layout_width="match_parent"
                android:layout_height="1dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/dialog_neutral"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="16sp"
                tools:text="App info" />

            <View
                android:id="@+id/line_neutral_cancel"
                android:layout_width="match_parent"
                android:layout_height="1dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/dialog_cancel_vertical"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#999999"
                android:textSize="16sp"
                tools:text="Not now" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
