<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/default_background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="TabLayout 示例配置"
                android:textColor="@color/autoColor"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="调整下方参数后进入对应示例页查看效果"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <!-- StyledTabLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="StyledTabLayout（圆角背景）"
                android:textColor="@color/autoColor"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_styled_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中字号：12sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_styled_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="2" />

            <TextView
                android:id="@+id/tv_styled_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中字号：12sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_styled_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_styled_selected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_styled_unselected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_styled_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="圆角半径：23dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_styled_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="22"
                android:progress="15" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_styled_selected_bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:checked="true"
                android:text="选中加粗"
                android:textColor="@color/autoColor" />

            <!-- Fixed TabLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="TabLayout（固定指示条）"
                android:textColor="@color/autoColor"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_fixed_indicator_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条宽度：24dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_fixed_indicator_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="36"
                android:progress="12" />

            <TextView
                android:id="@+id/tv_fixed_indicator_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条高度：3dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_fixed_indicator_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="6"
                android:progress="1" />

            <TextView
                android:id="@+id/tv_fixed_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中字号：14sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_fixed_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="4" />

            <TextView
                android:id="@+id/tv_fixed_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中字号：12sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_fixed_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_fixed_selected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_fixed_unselected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_fixed_indicator_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_fixed_selected_bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:checked="true"
                android:text="选中加粗"
                android:textColor="@color/autoColor" />

            <!-- IndicatorTabLayout -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="IndicatorTabLayout（Canvas 指示条）"
                android:textColor="@color/autoColor"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_indicator_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条宽度：12dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_indicator_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="24"
                android:progress="4" />

            <TextView
                android:id="@+id/tv_indicator_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条高度：4dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_indicator_height"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="6"
                android:progress="2" />

            <TextView
                android:id="@+id/tv_indicator_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条圆角：8dp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_indicator_corner_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="16"
                android:progress="8" />

            <TextView
                android:id="@+id/tv_indicator_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中字号：14sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_indicator_selected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="4" />

            <TextView
                android:id="@+id/tv_indicator_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中字号：12sp"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_indicator_unselected_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:max="8"
                android:progress="2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_indicator_selected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未选中文字颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_indicator_unselected_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="指示条颜色"
                android:textColor="@color/dark_light"
                android:textSize="12sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/chips_indicator_bar_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_indicator_selected_bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:checked="true"
                android:text="选中加粗"
                android:textColor="@color/autoColor" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="进入示例"
                android:textColor="@color/autoColor"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_material_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Material TabLayout（BaseViewPagerFragment）"
                android:textColor="@color/autoColor"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:id="@+id/btn_styled_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="圆角背景 Tab（BaseStyledViewPagerFragment）"
                android:textColor="@color/autoColor"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:id="@+id/btn_fixed_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="固定指示条 Tab（BaseFixedTabViewPagerFragment）"
                android:textColor="@color/autoColor"
                tools:ignore="RtlSymmetry" />

            <TextView
                android:id="@+id/btn_indicator_tab"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Canvas 指示条 Tab（BaseIndicatorViewPagerFragment）"
                android:textColor="@color/autoColor"
                tools:ignore="RtlSymmetry" />
        </LinearLayout>
    </ScrollView>
</layout>
